# Эта папка предназначена для статических ресурсов
# Все файлы из этой папки будут доступны по корневому пути сайта
# Например: /favicon.ico, /images/logo.png и т.д.

# Структура папки public:
# /public
#   /images      - изображения
#   /icons       - иконки
#   /fonts       - шрифты (если нужны)
#   /videos      - видео файлы
#   favicon.ico  - иконка сайта

